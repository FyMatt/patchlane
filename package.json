{
  "name": "patchlane",
  "displayName": "Patchlane",
  "description": "面向中文开发者的 AI 编程助手，支持 DeepSeek 优先接入、可确认修改、Skill、MCP 和会话审批。",
  "version": "0.0.1",
  "publisher": "FyMatt",
  "license": "MIT",
  "icon": "media/marketplace-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/FyMatt/patchlane.git"
  },
  "bugs": {
    "url": "https://github.com/FyMatt/patchlane/issues"
  },
  "homepage": "https://github.com/FyMatt/patchlane#readme",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "code agent",
    "deepseek",
    "llm",
    "mcp",
    "vscode",
    "中文"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:codeAgent.chatView",
    "onCommand:codeAgent.setApiKey",
    "onCommand:codeAgent.setActiveProviderApiKey",
    "onCommand:codeAgent.configureCustomProvider",
    "onCommand:codeAgent.configureWebSearch",
    "onCommand:codeAgent.createCapabilityTemplates",
    "onCommand:codeAgent.switchModel",
    "onCommand:codeAgent.openChat",
    "onCommand:codeAgent.runVerify",
    "onCommand:codeAgent.generatePatch",
    "onCommand:codeAgent.applyPatch",
    "onCommand:codeAgent.applySelectedPatchHunks",
    "onCommand:codeAgent.rollbackPatch",
    "onCommand:codeAgent.indexWorkspace",
    "onCommand:codeAgent.explainSelection",
    "onCommand:codeAgent.patchSelection"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeAgent.setApiKey",
        "title": "Patchlane: 设置 DeepSeek API Key"
      },
      {
        "command": "codeAgent.setActiveProviderApiKey",
        "title": "Patchlane: 设置当前模型 API Key"
      },
      {
        "command": "codeAgent.configureCustomProvider",
        "title": "Patchlane: 配置自定义模型"
      },
      {
        "command": "codeAgent.configureWebSearch",
        "title": "Patchlane: 配置联网搜索"
      },
      {
        "command": "codeAgent.createCapabilityTemplates",
        "title": "Patchlane: 生成 Skill / MCP 模板"
      },
      {
        "command": "codeAgent.switchModel",
        "title": "Patchlane: 切换模型"
      },
      {
        "command": "codeAgent.openChat",
        "title": "Patchlane: 打开会话"
      },
      {
        "command": "codeAgent.runVerify",
        "title": "Patchlane: 运行验证命令"
      },
      {
        "command": "codeAgent.generatePatch",
        "title": "Patchlane: 生成修改"
      },
      {
        "command": "codeAgent.applyPatch",
        "title": "Patchlane: 应用待确认修改"
      },
      {
        "command": "codeAgent.applySelectedPatchHunks",
        "title": "Patchlane: 部分应用修改"
      },
      {
        "command": "codeAgent.rollbackPatch",
        "title": "Patchlane: 撤回上次修改"
      },
      {
        "command": "codeAgent.indexWorkspace",
        "title": "Patchlane: 索引工作区"
      },
      {
        "command": "codeAgent.explainSelection",
        "title": "Patchlane: 解释当前代码"
      },
      {
        "command": "codeAgent.patchSelection",
        "title": "Patchlane: 修改当前代码"
      }
    ],
    "configuration": {
      "title": "Patchlane",
      "properties": {
        "codeAgent.provider": {
          "type": "string",
          "default": "deepseek",
          "enum": [
            "deepseek",
            "openai",
            "anthropic",
            "doubao",
            "ernie",
            "qwen",
            "hunyuan",
            "glm",
            "spark",
            "ollama",
            "lmStudio",
            "custom"
          ],
          "description": "当前使用的模型厂商。"
        },
        "codeAgent.model": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "当前使用的模型 ID。"
        },
        "codeAgent.deepseek.baseUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "DeepSeek 的 OpenAI 兼容 API 地址。"
        },
        "codeAgent.deepseek.defaultModel": {
          "type": "string",
          "default": "deepseek-v4-flash",
          "description": "用于快速聊天任务的 DeepSeek 默认模型，旧配置仍可使用 deepseek-chat。"
        },
        "codeAgent.deepseek.advancedModel": {
          "type": "string",
          "default": "deepseek-v4-pro",
          "description": "用于复杂代码任务的 DeepSeek 高级模型，旧配置仍可使用 deepseek-reasoner。"
        },
        "codeAgent.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "OpenAI API 地址。"
        },
        "codeAgent.openai.gpt4oModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI GPT-4o 旧版兼容模型 ID。"
        },
        "codeAgent.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com/v1",
          "description": "Anthropic / Claude 兼容 API 地址。"
        },
        "codeAgent.anthropic.opusModel": {
          "type": "string",
          "default": "claude-opus-4-1",
          "description": "Claude Opus 模型 ID。"
        },
        "codeAgent.anthropic.sonnetModel": {
          "type": "string",
          "default": "claude-sonnet-4",
          "description": "Claude Sonnet 模型 ID。"
        },
        "codeAgent.anthropic.haikuModel": {
          "type": "string",
          "default": "claude-3-5-haiku-latest",
          "description": "Claude Haiku 模型 ID。"
        },
        "codeAgent.doubao.baseUrl": {
          "type": "string",
          "default": "https://ark.cn-beijing.volces.com/api/v3",
          "description": "豆包 OpenAI 兼容 API 地址。"
        },
        "codeAgent.doubao.model": {
          "type": "string",
          "default": "doubao-seed-code-preview-251028",
          "description": "豆包代码模型 ID。"
        },
        "codeAgent.ernie.baseUrl": {
          "type": "string",
          "default": "https://qianfan.baidubce.com/v2",
          "description": "文心一言兼容 API 地址。"
        },
        "codeAgent.ernie.model": {
          "type": "string",
          "default": "ernie-4.5-turbo-128k",
          "description": "文心一言模型 ID。"
        },
        "codeAgent.qwen.baseUrl": {
          "type": "string",
          "default": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "description": "通义千问 OpenAI 兼容 API 地址。"
        },
        "codeAgent.qwen.model": {
          "type": "string",
          "default": "qwen3-coder-next",
          "description": "通义千问代码模型 ID。"
        },
        "codeAgent.hunyuan.baseUrl": {
          "type": "string",
          "default": "https://api.hunyuan.cloud.tencent.com/v1",
          "description": "腾讯混元兼容 API 地址。"
        },
        "codeAgent.hunyuan.model": {
          "type": "string",
          "default": "hunyuan-turbos-latest",
          "description": "腾讯混元模型 ID。"
        },
        "codeAgent.glm.baseUrl": {
          "type": "string",
          "default": "https://open.bigmodel.cn/api/paas/v4",
          "description": "智谱 GLM OpenAI 兼容 API 地址。"
        },
        "codeAgent.glm.model": {
          "type": "string",
          "default": "glm-4.7",
          "description": "智谱 GLM 模型 ID。"
        },
        "codeAgent.spark.baseUrl": {
          "type": "string",
          "default": "https://spark-api-open.xf-yun.com/x2",
          "description": "星火 X2 OpenAI 兼容 API 地址。"
        },
        "codeAgent.spark.model": {
          "type": "string",
          "default": "spark-x",
          "description": "星火模型 ID。"
        },
        "codeAgent.ollama.baseUrl": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Ollama OpenAI 兼容 API 地址。"
        },
        "codeAgent.ollama.model": {
          "type": "string",
          "default": "qwen3-coder:latest",
          "description": "Ollama 本地模型 ID。"
        },
        "codeAgent.lmStudio.baseUrl": {
          "type": "string",
          "default": "http://localhost:1234/v1",
          "description": "LM Studio OpenAI 兼容 API 地址。"
        },
        "codeAgent.lmStudio.model": {
          "type": "string",
          "default": "local-model",
          "description": "LM Studio 本地模型 ID。"
        },
        "codeAgent.custom.protocol": {
          "type": "string",
          "default": "openai",
          "enum": [
            "openai",
            "anthropic"
          ],
          "description": "自定义模型使用的接口协议。"
        },
        "codeAgent.custom.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "自定义模型的 Base URL。"
        },
        "codeAgent.custom.model": {
          "type": "string",
          "default": "gpt-5.4-mini",
          "description": "自定义模型 ID。"
        },
        "codeAgent.modelPolicy.enabled": {
          "type": "boolean",
          "default": true,
          "description": "在支持的厂商中，根据任务自动选择快速模型或高级模型。"
        },
        "codeAgent.modelParameters.temperature": {
          "type": "number",
          "default": 0.2,
          "minimum": 0,
          "maximum": 2,
          "description": "模型请求使用的采样温度。"
        },
        "codeAgent.modelParameters.maxTokens": {
          "type": "number",
          "default": 4096,
          "minimum": 0,
          "description": "模型最大输出 token 数；设为 0 则不传该参数。"
        },
        "codeAgent.modelParameters.topP": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "maximum": 1,
          "description": "Top-p 采样参数；设为 0 则不传该参数。"
        },
        "codeAgent.http.proxy": {
          "type": "string",
          "default": "",
          "description": "可选代理地址，供支持显式代理配置的厂商使用。"
        },
        "codeAgent.webSearch.enabled": {
          "type": "boolean",
          "default": false,
          "description": "启用联网搜索工具，用于获取最新文档、网页和公开资料。"
        },
        "codeAgent.webSearch.provider": {
          "type": "string",
          "default": "free",
          "enum": [
            "free",
            "custom",
            "searxng",
            "tavily",
            "brave",
            "bing",
            "serpapi"
          ],
          "description": "联网搜索使用的服务商。free 为无需 Key 的免费搜索，会优先尝试 Bing HTML、百度、搜狗、DuckDuckGo HTML，再轮询公开 SearXNG 实例。"
        },
        "codeAgent.webSearch.baseUrl": {
          "type": "string",
          "default": "",
          "description": "搜索服务 Base URL。免费搜索可留空；也可以填写自建 SearXNG 地址。"
        },
        "codeAgent.webSearch.maxResults": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 10,
          "description": "单次搜索返回的结果数量。"
        },
        "codeAgent.webSearch.defaultRecencyDays": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "默认的搜索时间范围（天）。"
        },
        "codeAgent.webSearch.allowedDomains": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "允许联网搜索访问的域名白名单。"
        },
        "codeAgent.webSearch.blockedDomains": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "联网搜索要过滤掉的域名黑名单。"
        },
        "codeAgent.webSearch.requireApproval": {
          "type": "boolean",
          "default": true,
          "description": "每次联网搜索前是否要求审批。"
        },
        "codeAgent.verify.commands": {
          "type": "array",
          "default": [
            "npm test"
          ],
          "items": {
            "type": "string"
          },
          "description": "Agent 可运行的工作区验证命令。"
        },
        "codeAgent.agent.maxRepairAttempts": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 4,
          "description": "验证并修复最多自动生成几轮修复草稿。每轮仍需要用户审查 diff，Patchlane 不会自动写入文件。"
        },
        "codeAgent.agent.maxToolRounds": {
          "type": "number",
          "default": 2,
          "minimum": 1,
          "maximum": 4,
          "description": "Agent 生成修改前最多进行几轮模型驱动工具循环。轮次越高越稳，但会消耗更多 token。"
        },
        "codeAgent.agent.contextBudget": {
          "type": "string",
          "default": "balanced",
          "enum": [
            "economy",
            "balanced",
            "quality"
          ],
          "enumDescriptions": [
            "省 token：少读文件、少带历史，适合日常小修改和低成本模型。",
            "均衡：默认策略，优先当前文件、打开文件和高相关文件。",
            "高质量：扩大上下文预算，适合复杂重构和多文件任务。"
          ],
          "description": "Agent 上下文预算档位，用于在质量和 token 成本之间取舍。"
        },
        "codeAgent.index.maxFiles": {
          "type": "number",
          "default": 250,
          "description": "轻量索引最多纳入的工作区文件数量。"
        },
        "codeAgent.index.exclude": {
          "type": "string",
          "default": "**/{node_modules,dist,out,build,.next,.git,.codex,coverage,.turbo,.cache,tmp,temp}/**",
          "description": "工作区索引和引用文件列表需要排除的目录。"
        },
        "codeAgent.customSkills": {
          "type": "array",
          "default": [],
          "description": "显示在 Skill 选择器中的自定义 Skill。",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "唯一 Skill ID。"
              },
              "label": {
                "type": "string",
                "description": "显示名称。"
              },
              "description": {
                "type": "string",
                "description": "简短说明。"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "builtin",
                  "custom",
                  "mcp"
                ],
                "default": "custom",
                "description": "Skill 来源，用于展示和后续路由。"
              },
              "command": {
                "type": "string",
                "description": "可选 VS Code 命令 ID 或执行器提示。"
              },
              "server": {
                "type": "string",
                "description": "当 Skill 使用 MCP 时填写可选 MCP 服务名。"
              },
              "script": {
                "type": "string",
                "description": "可选工作区相对脚本路径。"
              },
              "runtime": {
                "type": "string",
                "enum": [
                  "node",
                  "python",
                  "shell",
                  "mcp",
                  "custom"
                ],
                "description": "Skill 脚本使用的运行时。"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "可选固定脚本参数。"
              }
            },
            "required": [
              "id",
              "label",
              "description"
            ]
          }
        },
        "codeAgent.customTools": {
          "type": "array",
          "default": [],
          "description": "显示在工具选择器中的自定义工具和 MCP 入口。",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "唯一工具 ID。"
              },
              "label": {
                "type": "string",
                "description": "显示名称。"
              },
              "description": {
                "type": "string",
                "description": "简短说明。"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "builtin",
                  "custom",
                  "mcp"
                ],
                "default": "custom",
                "description": "工具类型，用于展示和后续路由。"
              },
              "command": {
                "type": "string",
                "description": "可选命令 ID 或执行器提示。"
              },
              "server": {
                "type": "string",
                "description": "可选 MCP 服务名。"
              },
              "script": {
                "type": "string",
                "description": "可选工作区相对脚本路径或 MCP 服务入口。"
              },
              "runtime": {
                "type": "string",
                "enum": [
                  "node",
                  "python",
                  "shell",
                  "mcp",
                  "custom"
                ],
                "description": "工具或 MCP 服务使用的运行时。"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "可选固定脚本参数。"
              }
            },
            "required": [
              "id",
              "label",
              "description"
            ]
          }
        },
        "codeAgent.mcp.servers": {
          "type": "object",
          "default": {},
          "description": "MCP Server 配置。支持 stdio MCP 工具发现；tools 可手动声明，也可在 Patchlane 设置页点击发现自动读取。",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "是否启用该 MCP 服务。"
              },
              "transport": {
                "type": "string",
                "enum": [
                  "stdio",
                  "http"
                ],
                "default": "stdio",
                "description": "MCP 传输方式。支持 stdio 和 HTTP JSON-RPC。"
              },
              "command": {
                "type": "string",
                "description": "stdio MCP Server 启动命令。"
              },
              "args": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "启动参数，支持 ${workspaceFolder}。"
              },
              "cwd": {
                "type": "string",
                "description": "工作目录，默认当前工作区，支持 ${workspaceFolder}。"
              },
              "env": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "环境变量，支持 ${workspaceFolder}。"
              },
              "url": {
                "type": "string",
                "description": "HTTP MCP 地址。支持 Streamable HTTP / JSON-RPC 端点。"
              },
              "headers": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                },
                "description": "HTTP MCP 额外请求头，例如鉴权或网关需要的自定义头。"
              },
              "tools": {
                "type": "array",
                "description": "要显示到 Patchlane 工具选择器的 MCP 工具。",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "MCP tool name。"
                    },
                    "label": {
                      "type": "string",
                      "description": "显示名称。"
                    },
                    "description": {
                      "type": "string",
                      "description": "工具说明。"
                    }
                  },
                  "required": [
                    "name"
                  ]
                }
              }
            }
          }
        },
        "codeAgent.openai.gpt55Model": {
          "type": "string",
          "default": "gpt-5.5",
          "description": "内置 OpenAI 预设使用的 GPT-5.5 模型 ID。"
        },
        "codeAgent.openai.gpt54Model": {
          "type": "string",
          "default": "gpt-5.4",
          "description": "内置 OpenAI 预设使用的 GPT-5.4 模型 ID。"
        },
        "codeAgent.openai.gpt54MiniModel": {
          "type": "string",
          "default": "gpt-5.4-mini",
          "description": "内置 OpenAI 预设使用的 GPT-5.4 mini 模型 ID。"
        },
        "codeAgent.openai.gpt54NanoModel": {
          "type": "string",
          "default": "gpt-5.4-nano",
          "description": "内置 OpenAI 预设使用的 GPT-5.4 nano 模型 ID。"
        },
        "codeAgent.openai.gpt41Model": {
          "type": "string",
          "default": "gpt-4.1",
          "description": "OpenAI GPT-4.1 兼容模型 ID。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeAgent",
          "title": "Patchlane",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codeAgent": [
        {
          "type": "webview",
          "id": "codeAgent.chatView",
          "name": "会话"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codeAgent.switchModel",
          "when": "view == codeAgent.chatView",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "codeAgent.explainSelection",
          "when": "editorTextFocus",
          "group": "codeAgent@1"
        },
        {
          "command": "codeAgent.patchSelection",
          "when": "editorTextFocus",
          "group": "codeAgent@2"
        }
      ]
    }
  },
  "scripts": {
    "build:webview:js": "node esbuild.webview.mjs",
    "build:webview:css": "tailwindcss -i ./src/webview/styles.css -o ./media/webview/styles.css --minify",
    "check:webview": "tsc -p ./tsconfig.webview.json",
    "build:webview": "npm run check:webview && npm run build:webview:js && npm run build:webview:css",
    "compile": "tsc -p ./ && npm run build:webview",
    "test": "npm run compile && node dist/test/patchService.test.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package --allow-missing-repository",
    "package:vsix": "npm run package",
    "watch": "tsc -watch -p ./",
    "watch:webview": "node esbuild.webview.mjs --watch"
  },
  "devDependencies": {
